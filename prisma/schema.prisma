generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Institution {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  sites     Site[]
  users     User[]
}

model Site {
  id                  String                   @id @default(cuid())
  name                String
  institutionId       String
  isActive            Boolean                  @default(true)
  createdAt           DateTime                 @default(now())
  operatorAssignments OperatorSiteAssignment[]
  institution         Institution              @relation(fields: [institutionId], references: [id])
  studies             Study[]
  users               User[]
}

model User {
  id                  String                   @id @default(cuid())
  name                String
  email               String                   @unique
  password            String
  role                UserRole
  institutionId       String?
  siteId              String?
  isActive            Boolean                  @default(true)
  createdAt           DateTime                 @default(now())
  operatorAssignments OperatorSiteAssignment[] @relation("OperatorAssignments")
  doctorStudies       Study[]                  @relation("DoctorStudies")
  operatorStudies     Study[]                  @relation("OperatorStudies")
  technicianStudies   Study[]                  @relation("TechnicianStudies")
  uploadedStudies     Study[]                  @relation("UploadedStudies")
  comments            StudyComment[]
  institution         Institution?             @relation(fields: [institutionId], references: [id])
  site                Site?                    @relation(fields: [siteId], references: [id])
}

model OperatorSiteAssignment {
  id         String   @id @default(cuid())
  operatorId String
  siteId     String
  createdAt  DateTime @default(now())
  operator   User     @relation("OperatorAssignments", fields: [operatorId], references: [id])
  site       Site     @relation(fields: [siteId], references: [id])

  @@unique([operatorId, siteId])
}

model Patient {
  id          String   @id @default(cuid())
  patientId   String
  patientName String
  createdAt   DateTime @default(now())
  studies     Study[]
}

model Study {
  id               String         @id @default(cuid())
  caseNumber       String         @unique
  studyDescription String?
  modality         String?
  status           StudyStatus    @default(UPLOADED)
  patientId        String?
  siteId           String
  technicianId     String?
  doctorId         String
  operatorId       String?
  imagingLink      String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  uploadedById     String
  report           Report?
  doctor           User           @relation("DoctorStudies", fields: [doctorId], references: [id])
  operator         User?          @relation("OperatorStudies", fields: [operatorId], references: [id])
  patient          Patient?       @relation(fields: [patientId], references: [id])
  site             Site           @relation(fields: [siteId], references: [id])
  technician       User?          @relation("TechnicianStudies", fields: [technicianId], references: [id])
  uploadedBy       User           @relation("UploadedStudies", fields: [uploadedById], references: [id])
  comments         StudyComment[]
  files            StudyFile[]

  @@index([siteId])
  @@index([doctorId])
  @@index([technicianId])
  @@index([uploadedById])
}

model StudyFile {
  id         String   @id @default(cuid())
  studyId    String
  fileName   String
  fileUrl    String
  fileType   String
  folderPath String?
  createdAt  DateTime @default(now())
  study      Study    @relation(fields: [studyId], references: [id])
}

model Report {
  id         String   @id @default(cuid())
  studyId    String   @unique
  reportUrl  String
  uploadedAt DateTime @default(now())
  study      Study    @relation(fields: [studyId], references: [id])
}

model StudyComment {
  id        String   @id @default(cuid())
  studyId   String
  userId    String
  message   String
  createdAt DateTime @default(now())
  study     Study    @relation(fields: [studyId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

enum UserRole {
  SUPER_ADMIN
  INSTITUTION_MANAGER
  SITE_ADMIN
  OPERATION_HEAD
  OPERATOR
  TECHNICIAN
  DOCTOR
}

enum StudyStatus {
  UPLOADED
  ASSIGNED
  PROCESSING
  READY
}
